<?xml version="1.0" encoding="utf-8"?>
<resources>
    <color name="ic_launcher_background">#C4A77D</color>
    <string name="accessibility_service_description">
        Tyme Boxed needs Accessibility to detect when a blocked app is opened during a
        focus session, and send you back to the home screen. It never reads screen
        content, messages, or personal data. You can revoke access any time.
    </string>
    <string name="accessibility_service_label">Tyme Boxed App Blocker</string>
    <string name="accessibility_service_summary">Blocks apps during a focus session</string>
    <string name="app_name">Tyme Boxed</string>
    <string name="session_channel_description">Ongoing notification shown while a focus session is running.</string>
    <string name="session_channel_name">Active Session</string>
    <style name="Theme.TymeBoxed" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
    </style>
</resources>